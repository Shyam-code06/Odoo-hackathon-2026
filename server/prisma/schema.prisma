// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS for Type Safety & System Consistency ---

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
  MAINTENANCE_MANAGER
  DRIVER_MANAGER
  VIEWER
  DRIVER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum VehicleType {
  VAN
  TRUCK
  SEMI_TRUCK
  SEDAN
  SUV
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  TOLL
  PARKING
  MAINTENANCE_COST
  DRIVER_ALLOWANCE
  FUEL
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  DEACTIVATE
  ACTIVATE
  RESET_PASSWORD
  LOGIN
  LOGOUT
}

// --- SCHEMAS / MODELS ---

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String                           // Hashed password
  name            String
  role            Role      @default(VIEWER)
  isActive        Boolean   @default(true)         // Soft deactivation
  isDefault       Boolean   @default(false)        // System default account; cannot be deleted
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Self-referential org relationship:
  // FLEET_MANAGER: fleetManagerId = null (they own the org)
  // All other roles: fleetManagerId = their Fleet Manager's User.id
  fleetManagerId  String?
  fleetManager    User?     @relation("OrgUsers", fields: [fleetManagerId], references: [id], onDelete: Restrict)
  orgUsers        User[]    @relation("OrgUsers")

  // Link User to Driver profile (1-to-1 relationship if the driver logs in)
  driver          Driver?

  // Data owned by this fleet manager (only populated when role = FLEET_MANAGER)
  vehicles        Vehicle[]
  drivers         Driver[]  @relation("FleetManagerDrivers")
  trips           Trip[]    @relation("FleetManagerTrips")
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  vehicleDocuments VehicleDocument[]

  // Audit trail
  auditLogs       AuditLog[] @relation("AuditUser")

  @@index([fleetManagerId])
  @@index([role])
  @@index([isActive])
}

model Vehicle {
  id                 String            @id @default(uuid())
  registrationNumber String            @unique // Enforces "Registration number must be unique"
  model              String
  type               VehicleType
  maxLoadCapacity    Float             // Cargo capacity limit in kilograms (kg)
  odometer           Float             // Current recorded distance (km)
  acquisitionCost    Decimal           @db.Decimal(12, 2)
  status             VehicleStatus     @default(AVAILABLE)
  region             String            // Used for dashboard filtering
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Org ownership — all vehicles belong to a Fleet Manager
  fleetManagerId     String
  fleetManager       User              @relation(fields: [fleetManagerId], references: [id])

  // Relationships
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
  documents          VehicleDocument[]

  // Indexes for high performance filtering and dashboard counting
  @@index([status])
  @@index([type])
  @@index([region])
  @@index([fleetManagerId])
}

model Driver {
  id                String       @id @default(uuid())
  userId            String?      @unique // Optional link to User login table
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name              String
  licenseNumber     String       @unique
  licenseCategory   String       // class A, B, etc.
  licenseExpiryDate DateTime     // Used to check validity before assigning to a trip
  contactNumber     String
  safetyScore       Float        @default(100.0) // Defaults to perfect 100
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Org ownership
  fleetManagerId    String
  fleetManager      User         @relation("FleetManagerDrivers", fields: [fleetManagerId], references: [id])

  // Relationships
  trips             Trip[]

  @@index([status])
  @@index([licenseExpiryDate])
  @@index([fleetManagerId])
}

model Trip {
  id              String      @id @default(uuid())
  tripNumber      String      @unique // Human-readable identifier like TRIP-10023
  source          String
  destination     String
  cargoWeight     Float       // Must satisfy: CargoWeight <= Vehicle.maxLoadCapacity
  plannedDistance Float       // Distance in km
  actualDistance  Float?      // To update the vehicle's odometer on completion
  status          TripStatus  @default(DRAFT)
  revenue         Decimal     @default(0.00) @db.Decimal(12, 2)
  dispatchTime    DateTime?
  completionTime  DateTime?

  // Relationships / Foreign Keys
  vehicleId       String
  vehicle         Vehicle     @relation(fields: [vehicleId], references: [id])
  driverId        String
  driver          Driver      @relation(fields: [driverId], references: [id])

  // Org ownership
  fleetManagerId  String
  fleetManager    User        @relation("FleetManagerTrips", fields: [fleetManagerId], references: [id])

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Logs recorded for this specific trip
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([fleetManagerId])
}

model MaintenanceLog {
  id             String    @id @default(uuid())
  description    String    // "Oil change", "Brake pad replacement", etc.
  cost           Decimal   @db.Decimal(12, 2)
  startDate      DateTime  @default(now())
  endDate        DateTime? // Nullable. When filled, maintenance is complete.
  isClosed       Boolean   @default(false)

  // Relationships
  vehicleId      String
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])

  // Org ownership
  fleetManagerId String
  fleetManager   User      @relation(fields: [fleetManagerId], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([vehicleId])
  @@index([isClosed])
  @@index([fleetManagerId])
}

model FuelLog {
  id             String   @id @default(uuid())
  liters         Float
  cost           Decimal  @db.Decimal(12, 2)
  date           DateTime @default(now())
  odometer       Float    // Odometer reading at moment of refueling (for mpg validation)

  // Relationships
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId         String?  // Optional context link to a Trip
  trip           Trip?    @relation(fields: [tripId], references: [id])

  // Org ownership
  fleetManagerId String
  fleetManager   User     @relation(fields: [fleetManagerId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([vehicleId])
  @@index([tripId])
  @@index([fleetManagerId])
}

model Expense {
  id             String          @id @default(uuid())
  amount         Decimal         @db.Decimal(12, 2)
  category       ExpenseCategory
  date           DateTime        @default(now())
  description    String?

  // Relationships
  vehicleId      String
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id])
  tripId         String?
  trip           Trip?           @relation(fields: [tripId], references: [id])

  // Org ownership
  fleetManagerId String
  fleetManager   User            @relation(fields: [fleetManagerId], references: [id])

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([vehicleId])
  @@index([tripId])
  @@index([category])
  @@index([fleetManagerId])
}

model VehicleDocument {
  id             String   @id @default(uuid())
  documentType   String   // "Insurance", "Registration", "Pollution Permit"
  documentUrl    String   // Storage bucket link for documents
  expiryDate     DateTime

  // Relationships
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id])

  // Org ownership
  fleetManagerId String
  fleetManager   User     @relation(fields: [fleetManagerId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([vehicleId])
  @@index([expiryDate])
  @@index([fleetManagerId])
}

model AuditLog {
  id           String      @id @default(uuid())
  action       AuditAction
  resourceType String      // "Vehicle", "Driver", "Trip", etc.
  resourceId   String?     // The ID of the affected record
  description  String?     // Human-readable description
  metadata     Json?       // Optional extra data (before/after values)
  timestamp    DateTime    @default(now())

  // Who performed the action
  userId       String
  user         User        @relation("AuditUser", fields: [userId], references: [id])
  userRole     String      // Snapshot of role at time of action
  fleetManagerId String    // Which org this belongs to

  @@index([userId])
  @@index([fleetManagerId])
  @@index([resourceType])
  @@index([timestamp])
}
